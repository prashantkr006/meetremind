# Google OAuth (https://console.cloud.google.com)
# Create a project → Enable "Google Calendar API" → OAuth 2.0 Client IDs → Desktop app
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft Azure (https://portal.azure.com → App registrations)
# Register app → Add redirect URI http://localhost:42814 → Grant "Calendars.Read" permission
MICROSOFT_CLIENT_ID=your-microsoft-app-client-id
